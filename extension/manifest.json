{
  "manifest_version": 3,
  "name": "Tab Out",
  "version": "1.1.0",
  "description": "掌控你的标签页。新标签页仪表盘，按域名分组展示所有打开的标签页，一键关闭、收藏、搜索、分类命名。",
  "permissions": ["tabs", "activeTab", "storage"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Out",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
